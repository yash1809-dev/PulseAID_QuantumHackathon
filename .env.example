# PulseAID — Environment Variables
# 
# Copy this file to .env and fill in your values.
# The .env file IS committed in this repo for hackathon demo purposes (public Mapbox token only).
# Never commit private keys, payment secrets, or database credentials.

# Mapbox GL JS public token (get yours at https://account.mapbox.com)
VITE_MAPBOX_TOKEN=your_mapbox_public_token_here
